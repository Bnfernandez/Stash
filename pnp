
# =========================
# CONFIG CONTENT TYPES
# =========================

$contentTypes = @(
    "ContentType1",
    "ContentType2",
    "ContentType3",
    "ContentType4",
    "ContentType5"
)

# =========================
# CONFIG FIELDS
# =========================

$fields = @(
    @{
        DisplayName = "Statut"
        InternalName = "Statut"
        Type = "Choice"
        Choices = @("Actif", "Inactif", "En attente")
    },
    @{
        DisplayName = "Priorité"
        InternalName = "Priorite"
        Type = "Choice"
        Choices = @("Haute", "Moyenne", "Basse")
    },
    @{
        DisplayName = "Code Projet"
        InternalName = "CodeProjet"
        Type = "Text"
        MaxLength = 15
    }
)

# =========================
# 1. ENSURE FIELDS (NO UPDATE)
# =========================

foreach ($field in $fields) {

    $existing = Get-PnPField -Identity $field.InternalName -ErrorAction SilentlyContinue

    if (-not $existing) {

        Write-Host "Création champ : $($field.InternalName)" -ForegroundColor Cyan

        if ($field.Type -eq "Choice") {

            Add-PnPField `
                -DisplayName $field.DisplayName `
                -InternalName $field.InternalName `
                -Type Choice `
                -Choices $field.Choices `
                -Group "Custom Columns"
        }
        elseif ($field.Type -eq "Text" -and $field.MaxLength) {

            Add-PnPField `
                -DisplayName $field.DisplayName `
                -InternalName $field.InternalName `
                -Type Text `
                -MaxLength $field.MaxLength `
                -Group "Custom Columns"
        }
        else {

            Add-PnPField `
                -DisplayName $field.DisplayName `
                -InternalName $field.InternalName `
                -Type $field.Type `
                -Group "Custom Columns"
        }
    }
    else {
        Write-Host "Champ existant : $($field.InternalName)" -ForegroundColor DarkGray
    }
}

# =========================
# 2. ENSURE FIELDS IN CONTENT TYPES + REQUIRED
# =========================

foreach ($ctName in $contentTypes) {

    Write-Host "Analyse CT : $ctName" -ForegroundColor Cyan

    $ct = Get-PnPContentType -Identity $ctName
    Get-PnPProperty -ClientObject $ct -Property FieldLinks

    $updated = $false

    foreach ($field in $fields) {

        $fieldLink = $ct.FieldLinks | Where-Object { $_.Name -eq $field.InternalName }

        # Ajouter si absent
        if (-not $fieldLink) {

            Write-Host "Ajout $($field.InternalName) -> $ctName" -ForegroundColor Yellow

            Add-PnPFieldToContentType `
                -Field $field.InternalName `
                -ContentType $ctName

            # reload
            $ct = Get-PnPContentType -Identity $ctName
            Get-PnPProperty -ClientObject $ct -Property FieldLinks

            $fieldLink = $ct.FieldLinks | Where-Object { $_.Name -eq $field.InternalName }
            $updated = $true
        }

        # Gestion Required
        if ($fieldLink -and $field.Required -ne $null) {

            if ($fieldLink.Required -ne $field.Required) {

                Write-Host "Required=$($field.Required) pour $($field.InternalName) dans $ctName" -ForegroundColor Yellow

                $fieldLink.Required = $field.Required
                $updated = $true
            }
        }
    }

    # Apply update + propagation si nécessaire
    if ($updated) {

        Write-Host "Mise à jour CT : $ctName" -ForegroundColor Cyan

        $ct.Update($true)
        Invoke-PnPQuery
    }
    else {
        Write-Host "Aucune modification pour $ctName" -ForegroundColor DarkGray
    }
}

Write-Host "✔ Script terminé (idempotent)" -ForegroundColor Green

