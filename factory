using System.Net.Http;
using System.Text.Json;
using System.Threading;
using System.Threading.Tasks;
using Microsoft.Extensions.Diagnostics.HealthChecks;

public class DocuSignESignatureHealthCheck : IHealthCheck
{
    private readonly HttpClient _httpClient;
    private const string StatusUrl = "https://status.docusign.com/api/v2/summary.json";

    public DocuSignESignatureHealthCheck(HttpClient httpClient)
    {
        _httpClient = httpClient;
    }

    public async Task<HealthCheckResult> CheckHealthAsync(
        HealthCheckContext context,
        CancellationToken cancellationToken = default)
    {
        try
        {
            using var response = await _httpClient.GetAsync(StatusUrl, cancellationToken);

            if (!response.IsSuccessStatusCode)
            {
                return HealthCheckResult.Unhealthy(
                    $"DocuSign status API returned {(int)response.StatusCode}.");
            }

            var json = await response.Content.ReadAsStringAsync(cancellationToken);
            using var doc = JsonDocument.Parse(json);

            // Find the eSignature component
            var components = doc.RootElement.GetProperty("components").EnumerateArray();
            string? eSignStatus = null;

            foreach (var component in components)
            {
                var name = component.GetProperty("name").GetString();
                if (name != null && name.Contains("eSignature", StringComparison.OrdinalIgnoreCase))
                {
                    eSignStatus = component.GetProperty("status").GetString();
                    break;
                }
            }

            if (string.IsNullOrEmpty(eSignStatus))
            {
                return HealthCheckResult.Degraded("Unable to locate eSignature component in DocuSign status response.");
            }

            // Typical values: "operational", "degraded_performance", "partial_outage", "major_outage"
            return eSignStatus.Equals("operational", StringComparison.OrdinalIgnoreCase)
                ? HealthCheckResult.Healthy("DocuSign eSignature API is operational.")
                : HealthCheckResult.Degraded($"DocuSign eSignature API reports: {eSignStatus}");
        }
        catch (Exception ex)
        {
            return HealthCheckResult.Unhealthy("Error checking DocuSign eSignature API status.", ex);
        }
    }
}

builder.Services.AddHttpClient<DocuSignESignatureHealthCheck>(client =>
{
    client.Timeout = TimeSpan.FromSeconds(5);
});

builder.Services.AddHealthChecks()
    .AddCheck<DocuSignESignatureHealthCheck>("docusign_esignature");
app.MapHealthChecks("/health");
