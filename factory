using System;
using System.Net.Http;
using System.Net.Http.Headers;
using System.Threading.Tasks;
using Newtonsoft.Json;
using Newtonsoft.Json.Linq;

public class IdEvidenceService
{
    private readonly string _basePath;  // e.g. "https://demo.docusign.net/restapi"
    private readonly string _accessToken;
    private readonly HttpClient _httpClient;

    public IdEvidenceService(string basePath, string accessToken)
    {
        _basePath = basePath.TrimEnd('/');
        _accessToken = accessToken;

        _httpClient = new HttpClient();
        _httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", accessToken);
    }

    /// <summary>
    /// Get the resource token for a recipient (step 3).
    /// You need to call the EnvelopesRecipients:createRecipientProofFileResourceToken endpoint.
    /// </summary>
    public async Task<string> GetResourceTokenAsync(string accountId, string envelopeId, string recipientId)
    {
        // Construct the URL for resource token request (doc says to use EnvelopesRecipients:createRecipientProofFileResourceToken).
        string url = $"{_basePath}/v2.1/accounts/{accountId}/envelopes/{envelopeId}/recipients/{recipientId}/proof_file_resource_token";

        var response = await _httpClient.PostAsync(url, null);
        response.EnsureSuccessStatusCode();
        string content = await response.Content.ReadAsStringAsync();
        var obj = JObject.Parse(content);
        string resourceToken = (string)obj["resourceToken"];
        return resourceToken;
    }

    /// <summary>
    /// Retrieve ID Evidence events (step 4) using listEventsByEntityIdFormat.
    /// </summary>
    public async Task<JObject> GetIdEvidenceEventsAsync(string accountId, string envelopeId, string recipientId, string resourceToken, DateTime? fromDate = null, DateTime? toDate = null)
    {
        // The iEvidence events path from docs: /idevidence/events/list/{entityIdFormat}
        // Where entityIdFormat might be like: "envelopeId:recipientId"
        // Based on docs for listEventsByEntityIdFormat  [oai_citation:1‡Docusign Developer Center](https://developers.docusign.com/docs/idevidence-api/reference/idevidence/events/list/?utm_source=chatgpt.com)
        string entityIdFormat = $"{envelopeId}:{recipientId}";

        string url = $"{_basePath}/v2.1/accounts/{accountId}/idevidence/events/list/{entityIdFormat}";

        // Append query parameters if from/to dates are provided
        var query = System.Web.HttpUtility.ParseQueryString(string.Empty);
        if (fromDate != null)
            query["from_date"] = fromDate.Value.ToString("o");  // ISO 8601
        if (toDate != null)
            query["to_date"] = toDate.Value.ToString("o");

        if (query.Count > 0)
            url += "?" + query.ToString();

        // Include the resource token header as required
        var request = new HttpRequestMessage(HttpMethod.Get, url);
        request.Headers.Add("X-DocuSign-Resource-Token", resourceToken);

        var resp = await _httpClient.SendAsync(request);
        resp.EnsureSuccessStatusCode();
        string respContent = await resp.Content.ReadAsStringAsync();
        var json = JObject.Parse(respContent);
        return json;
    }
}
