using System.Net.Http;
using System.Text.Json;
using System.Threading;
using System.Threading.Tasks;
using Microsoft.Extensions.Diagnostics.HealthChecks;
using Microsoft.Extensions.Hosting;

public class DocuSignAdaptiveHealthCheck : IHealthCheck
{
    private readonly HttpClient _httpClient;
    private readonly IWebHostEnvironment _env;

    public DocuSignAdaptiveHealthCheck(HttpClient httpClient, IWebHostEnvironment env)
    {
        _httpClient = httpClient;
        _env = env;
    }

    public async Task<HealthCheckResult> CheckHealthAsync(
        HealthCheckContext context,
        CancellationToken cancellationToken = default)
    {
        try
        {
            if (_env.IsProduction())
            {
                // ✅ Production: use the official DocuSign status API
                const string statusUrl = "https://status.docusign.com/api/v2/summary.json";
                using var response = await _httpClient.GetAsync(statusUrl, cancellationToken);

                if (!response.IsSuccessStatusCode)
                    return HealthCheckResult.Unhealthy($"DocuSign status API returned {(int)response.StatusCode}");

                var json = await response.Content.ReadAsStringAsync(cancellationToken);
                using var doc = JsonDocument.Parse(json);

                // Extract eSignature component status
                string? eSignStatus = null;
                foreach (var component in doc.RootElement.GetProperty("components").EnumerateArray())
                {
                    var name = component.GetProperty("name").GetString();
                    if (name != null && name.Contains("eSignature", StringComparison.OrdinalIgnoreCase))
                    {
                        eSignStatus = component.GetProperty("status").GetString();
                        break;
                    }
                }

                if (string.IsNullOrEmpty(eSignStatus))
                    return HealthCheckResult.Degraded("Unable to locate eSignature component in DocuSign status.");

                return eSignStatus.Equals("operational", StringComparison.OrdinalIgnoreCase)
                    ? HealthCheckResult.Healthy("DocuSign eSignature (prod) is operational.")
                    : HealthCheckResult.Degraded($"DocuSign eSignature (prod) reports: {eSignStatus}");
            }
            else
            {
                // ✅ Non-prod: use the demo/sandbox REST API directly
                const string demoUrl = "https://demo.docusign.net/restapi/service_information";
                using var response = await _httpClient.GetAsync(demoUrl, cancellationToken);

                return response.IsSuccessStatusCode
                    ? HealthCheckResult.Healthy("DocuSign eSignature (sandbox) API is reachable.")
                    : HealthCheckResult.Unhealthy($"DocuSign sandbox API returned {(int)response.StatusCode}.");
            }
        }
        catch (Exception ex)
        {
            return HealthCheckResult.Unhealthy("Error checking DocuSign health.", ex);
        }
    }
}
